<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <package android:name="io.github.dokuendev.dokuenreader" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true">

        <service
            android:name=".JpdbDictionaryPluginService"
            android:exported="true">
            <intent-filter>
                <action android:name="io.github.dokuendev.dokuenreader.dictionary.BIND_DICTIONARY_SERVICE" />
                <category android:name="io.github.dokuendev.dokuenreader.category.DICTIONARY" />
            </intent-filter>

            <!-- REQUIRED: These five fields are mandatory -->
            <meta-data
                android:name="plugin_name"
                android:value="JPDB" />
            <meta-data
                android:name="plugin_version"
                android:value="1.0.0" />
            <meta-data
                android:name="plugin_author"
                android:value="Dokuen Reader" />
            <meta-data
                android:name="plugin_description"
                android:value="Online JPDB dictionary lookup and deck integrations." />
            <meta-data
                android:name="plugin_license"
                android:value="Apache 2.0" />

            <!-- Optional metadata -->
            <meta-data
                android:name="plugin_website"
                android:value="https://github.com/dokuen-dev/dokuen-plugin-jpdb" />
            <meta-data
                android:name="plugin_support_email"
                android:value="dokuen.reader@gmail.com" />
        </service>
    </application>

</manifest>

